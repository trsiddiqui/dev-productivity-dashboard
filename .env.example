# --- Server configuration ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Vercel Marketplace / Upstash Redis ---
# Pull these into .env.local with: vercel env pull .env.local --yes
# Marketplace installs may expose either the `UPSTASH_REDIS_REST_*` or `UPSTASH_KV_REST_API_*` pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_KV_REST_API_URL=
UPSTASH_KV_REST_API_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=ghp_yourtoken
# Optional: narrow search to org or repos for performance/rate-limits
GITHUB_ORG=
GITHUB_REPOS= # comma-separated like: owner1/repo1,owner2/repo2

# --- JIRA ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token
# Often 'customfield_10026' but can vary; check your JIRA instance
JIRA_STORY_POINTS_FIELD=customfield_10026
GITHUB_ORG=your-org
JIRA_BOARD_ID=126
NEXT_PUBLIC_JIRA_BOARD_ID=126
USER_ACCOUNTS=alice:passw0rd,bob:s3cret
